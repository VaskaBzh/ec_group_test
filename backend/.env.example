# Backend runtime environment — copy to `.env` and adjust for your setup.
# The credentials must match the PostgreSQL stack in the root docker-compose.yml
# (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / POSTGRES_PORT in the root .env).
DATABASE_URL="postgresql://app:app_password@localhost:5432/purchase_requests?schema=public"

# HTTP port for the NestJS app
PORT=3000

# Logging verbosity: DEBUG | INFO | WARN | ERROR (default: DEBUG)
LOG_LEVEL=DEBUG

# Secret used to sign JWT access tokens (use a long random value in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# Access-token lifetime — keep short (e.g. 15m, 900s)
JWT_ACCESS_TTL=15m

# Refresh-token lifetime (e.g. 7d, 12h)
JWT_REFRESH_TTL=7d

# Allowed CORS origins: * for any, or a comma-separated list of origins
CORS_ORIGIN=*
