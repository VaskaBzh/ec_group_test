// Prisma schema for the purchase-requests application.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Роль пользователя в системе.
enum UserRole {
  /// Заявитель: создаёт заявки на покупку.
  Requester
  /// Проверяющий: рассматривает заявки (подтверждает/отклоняет).
  Reviewer
}

/// Статус заявки на покупку.
enum RequestStatus {
  /// Ожидает рассмотрения.
  Pending
  /// Подтверждена проверяющим.
  Approved
  /// Отклонена проверяющим.
  Rejected
}

/// Пользователь приложения (заявитель или проверяющий).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Заявки, созданные этим пользователем.
  requests PurchaseRequest[]

  /// Refresh-токены активных и отозванных сессий пользователя.
  refreshTokens RefreshToken[]

  @@map("users")
}

/// Refresh-токен сессии пользователя.
///
/// В базе хранится только SHA-256-хеш значения токена (`tokenHash`), а не сам
/// токен: утечка таблицы не раскрывает действующие refresh-токены. Ротация и
/// разлогин выполняются проставлением `revokedAt`; строки не удаляются, чтобы
/// можно было обнаружить повторное использование уже отозванного токена.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  /// SHA-256-хеш значения refresh-токена (уникален, по нему идёт поиск).
  tokenHash String    @unique
  /// Момент истечения срока действия токена.
  expiresAt DateTime
  /// Момент отзыва (ротация или logout); `null` — токен ещё активен.
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  /// Владелец токена.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Заявка на покупку, поданная заявителем.
model PurchaseRequest {
  id        String        @id @default(uuid())
  title     String
  quantity  Int
  amount    Decimal       @db.Decimal(12, 2)
  comment   String?
  status    RequestStatus @default(Pending)
  authorId  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  /// Автор заявки.
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Индексы под сортировку и фильтрацию списка заявок.
  @@index([createdAt])
  @@index([status])
  @@index([amount])
  @@index([authorId])
  @@map("purchase_requests")
}
